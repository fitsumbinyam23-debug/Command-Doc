{
  "name": "command-doctor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node tests/smoke-tests.mjs && node tests/current-app-smoke.mjs",
    "test:core": "node tests/smoke-tests.mjs",
    "test:current": "node tests/current-app-smoke.mjs",
    "test:startup": "node tests/current-app-startup.mjs",
    "test:learning": "node tools/generate-learning-integrity.mjs --check && node tools/validate-learning-integrity.mjs && node tests/learning-integrity.mjs",
    "curriculum:generate": "node tools/generate-complete-curriculum.mjs",
    "test:curriculum": "node tools/generate-complete-curriculum.mjs --check && node tests/curriculum-coverage.mjs",
    "test:beginner-experience": "node tests/beginner-experience.mjs",
    "test:mission-studio": "node tests/mission-studio-design.mjs"
  }
}
