    {
      "id": "cisco_show_diagnostic_result",
      "vendor_label": "Cisco IOS",
      "vendor_key": "cisco_ios",
      "command": "show diagnostic result",
      "category": "system",
      "meaning": "Shows available Cisco diagnostic test results and their pass, fail, or not-run state.",
      "use_for": ["Review hardware self-test results", "Check a suspected module or platform fault"],
      "good_output": ["PASS on expected tests", "No failed hardware components"],
      "bad_output": ["FAIL", "ERROR", "Repeated incomplete tests"],
      "detection_patterns": ["show\\s+diagnostic\\s+result", "Diagnostic.*Result"],
      "diagnosis_rules": [],
      "next_commands": [{"command": "show logging", "why": "Checks whether diagnostic failures have related system events.", "meaning": "Shows buffered device logs.", "look_for_good": ["No repeated hardware faults"], "look_for_bad": ["Diagnostic failures", "Module errors"], "risk": "Safe read-only command"}],
      "safety_level": "Safe read-only command",
      "learning_note": "Viewing results is safe; starting an online diagnostic can be disruptive and is a separate action."
    },
